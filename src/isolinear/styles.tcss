/* Isolinear — calm, minimal secret manager.
   Hierarchy comes from spacing + weight, not loud colour blocks. One accent
   ($primary) marks focus + selection; $accent (green) marks a revealed value;
   $error (red) marks destructive actions. Everything else is neutral. */

Screen {
    background: $background;
    color: $foreground;
    padding: 1 2;
}

/* toasts — quiet card, hairline border */
Toast {
    background: $panel;
    border: round $border;
    color: $foreground;
}
Toast.-error {
    border: round $error;
}

/* footer — its own rounded card; only the key letters carry colour */
Footer {
    height: 3;
    border: round $border;
}
Footer > .footer-key--key {
    color: $secondary;
    text-style: bold;
}
Footer > .footer-key--description {
    color: $text-muted;
}

/* buttons — flat & compact, not Textual's default raised 3-row chip */
Button {
    height: 1;
    min-width: 12;
    border: none;
    padding: 0 2;
    margin: 0;
    background: $panel;
    color: $foreground;
}
Button:hover {
    background: $primary 25%;
}
Button:focus {
    background: $primary 40%;
    text-style: bold;
}
Button.-primary {
    background: $primary;
    color: $background;
    text-style: bold;
}
Button.-primary:focus {
    background: $primary-lighten-1;
}
Button.-error {
    background: $error;
    color: $background;
    text-style: bold;
}
Button.-error:focus {
    background: $error-lighten-1;
}

/* ── header bar — its own rounded card ───────────────────────── */
#banner {
    height: 3;
    border: round $border;
    padding: 0 2;
}
#banner #brand {
    width: auto;
    padding: 0 2 0 0;
    color: $secondary;
    text-style: bold;
}
#banner #breadcrumb {
    width: 1fr;
    color: $text-muted;
}
#banner #ws-status {
    width: auto;
    text-align: right;
    color: $text-muted;
}

/* filter bar — hidden until you press / */
#filter-bar {
    display: none;
    dock: bottom;
    height: 3;
    border: round $primary;
    background: $surface;
}

/* ── three-pane body — rounded, colour-coded cards ───────────── */
#body {
    height: 1fr;
}

.pane {
    height: 1fr;
    padding: 1 1 0 1;
    margin-right: 1;
}
#detail-pane {
    margin-right: 0;
}
/* each pane is outlined in its section colour — dim when idle, full when active */
#scopes-pane { border: round $scopes-color 35%; }
#secrets-pane { border: round $secrets-color 35%; }
#detail-pane { border: round $detail-color 35%; }
#scopes-pane:focus-within { border: round $scopes-color; }
#secrets-pane:focus-within { border: round $secrets-color; }
#detail-pane:focus-within { border: round $detail-color; }

#scopes-pane { width: 26; }
#secrets-pane { width: 1fr; min-width: 40; }
#detail-pane { width: 42; }

/* the scopes table cursor in the scopes section colour */
#scopes-table > .datatable--cursor {
    background: $scopes-color 18%;
}
#scopes-table:focus > .datatable--cursor {
    background: $scopes-color 40%;
}

DataTable {
    background: transparent;
    height: 1fr;
    scrollbar-size-horizontal: 0;  /* short columns never need it */
}
DataTable > .datatable--cursor {
    background: $primary 18%;
}
DataTable:focus > .datatable--cursor {
    background: $primary 30%;
}
/* the secrets table cursor in the secrets section colour */
#secrets-table > .datatable--cursor {
    background: $secrets-color 18%;
}
#secrets-table:focus > .datatable--cursor {
    background: $secrets-color 35%;
}
DataTable > .datatable--header {
    background: transparent;
    color: $text-muted;
    text-style: none;
}

/* ── detail pane ─────────────────────────────────────────────── */
#detail-body {
    padding: 0 1;
}
/* a revealed value — a quiet framed card, green = live */
.secret-value {
    display: none;
    border: round $detail-color;
    padding: 0 1;
    margin: 1 1 1 1;
    color: $detail-color;
}

/* friendly empty states */
.empty-hint {
    display: none;
    height: 1fr;
    padding: 2 2;
    content-align: center middle;
    text-align: center;
    color: $text-muted;
}

/* ── modals ──────────────────────────────────────────────────── */
/* darken the backdrop so the borderless dialog reads cleanly over the browser */
ModalScreen {
    align: center middle;
    background: $background 88%;
}
#dialog {
    width: 64;
    max-width: 90%;
    height: auto;          /* size to content — a compact card */
    max-height: 90%;
    padding: 1 3;
    border: round $border;
}
#dialog.danger {
    border: round $error;
}
#dialog.scope {
    border: round $scopes-color;
}
#dialog .dialog-title {
    text-style: bold;
    color: $foreground;
    margin-bottom: 1;
}
/* the dialog's actions, docked to the bottom like a status bar */
#dialog .dialog-hint {
    color: $text-muted;
    margin-top: 1;
}
#dialog.danger .dialog-title {
    color: $error;
}
#dialog Input {
    margin: 1 0;
}
#dialog .buttons {
    align-horizontal: right;
    height: auto;
    margin-top: 1;
}
#dialog Button {
    margin-left: 2;
}

/* workspace + help pickers reuse the dialog frame */
#picker-list {
    height: auto;
    max-height: 16;
    margin-top: 1;
}
.help-key {
    color: $secondary;
    text-style: bold;
}

#auth-table {
    height: auto;
    max-height: 16;
    margin-top: 1;
}
#acl-table {
    height: auto;
    max-height: 14;
    margin-top: 1;
}

/* ── login / onboarding ──────────────────────────────────────── */
LoginScreen {
    background: $background;
    align: center middle;
}
#login-card {
    width: 72;
    max-width: 92%;
    height: auto;
    padding: 2 4;
    border: round $border;
}
/* wider when showing the workspaces table */
#login-card.browse {
    width: 92;
}
#ws-table {
    height: auto;
    max-height: 12;
    margin-top: 1;
}
#login-wordmark {
    text-align: center;
    text-style: bold;
    color: $foreground;
}
#login-mark {
    text-align: center;
    margin-bottom: 1;
}
#login-tagline {
    text-align: center;
    color: $text-muted;
    margin-bottom: 1;
}
.login-section {
    color: $text-muted;
    text-style: bold;
    margin: 1 0 0 0;
}
#profiles {
    height: auto;
    max-height: 8;
    border: round $border;
    margin-top: 1;
}
#login-actions {
    height: 1;
    margin-top: 1;
    align-horizontal: center;
}
#login-actions Button {
    min-width: 0;
    margin: 0 1;
}
#login-status {
    height: auto;
    min-height: 1;
    margin-top: 1;
    text-align: center;
}
